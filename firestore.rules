rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }
    function isMember(tripId) {
      return signedIn() &&
        exists(/databases/$(database)/documents/trips/$(tripId)/members/$(request.auth.uid));
    }

    match /trips/{tripId} {
      allow create: if signedIn() &&
        request.resource.data.ownerId == request.auth.uid;
      allow read: if isMember(tripId);
      allow update: if isMember(tripId) &&
        request.resource.data.ownerId == resource.data.ownerId;
      allow delete: if signedIn() && resource.data.ownerId == request.auth.uid;

      match /members/{userId} {
        allow read: if isMember(tripId);
        allow create: if signedIn() && userId == request.auth.uid && (
          get(/databases/$(database)/documents/trips/$(tripId)).data.ownerId == request.auth.uid ||
          (
            request.resource.data.inviteToken is string &&
            exists(/databases/$(database)/documents/invites/$(request.resource.data.inviteToken)) &&
            get(/databases/$(database)/documents/invites/$(request.resource.data.inviteToken)).data.tripId == tripId &&
            get(/databases/$(database)/documents/invites/$(request.resource.data.inviteToken)).data.active == true
          )
        );
        allow update: if signedIn() && userId == request.auth.uid;
        allow delete: if signedIn() && (
          userId == request.auth.uid ||
          get(/databases/$(database)/documents/trips/$(tripId)).data.ownerId == request.auth.uid
        );
      }
    }

    match /invites/{token} {
      allow read: if signedIn();
      allow create: if signedIn() &&
        request.resource.data.createdBy == request.auth.uid &&
        isMember(request.resource.data.tripId);
      allow update, delete: if signedIn() && isMember(resource.data.tripId);
    }
  }
}
