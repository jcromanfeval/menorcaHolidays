rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }
    function isMember(tripId) {
      return signedIn() &&
        exists(/databases/$(database)/documents/trips/$(tripId)/members/$(request.auth.uid));
    }
    function keepsTripIdentity() {
      return request.resource.data.ownerId == resource.data.ownerId &&
        request.resource.data.inviteToken == resource.data.inviteToken &&
        request.resource.data.name == resource.data.name;
    }
    function validSharedStateUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['state', 'updatedAt', 'updatedBy', 'updatedByName']) &&
        request.resource.data.updatedBy is string &&
        request.resource.data.updatedByName is string;
    }

    match /trips/{tripId} {
      allow create: if signedIn() &&
        request.resource.data.ownerId == request.auth.uid;
      allow read: if isMember(tripId) || resource.data.inviteToken is string;
      allow update: if keepsTripIdentity() && (
        isMember(tripId) ||
        (!signedIn() && validSharedStateUpdate())
      );
      allow delete: if signedIn() && resource.data.ownerId == request.auth.uid;

      match /members/{userId} {
        allow read: if isMember(tripId);
        allow create: if signedIn() && userId == request.auth.uid && (
          get(/databases/$(database)/documents/trips/$(tripId)).data.ownerId == request.auth.uid ||
          (
            request.resource.data.inviteToken is string &&
            exists(/databases/$(database)/documents/invites/$(request.resource.data.inviteToken)) &&
            get(/databases/$(database)/documents/invites/$(request.resource.data.inviteToken)).data.tripId == tripId &&
            get(/databases/$(database)/documents/invites/$(request.resource.data.inviteToken)).data.active == true
          )
        );
        allow update: if signedIn() && userId == request.auth.uid;
        allow delete: if signedIn() && (
          userId == request.auth.uid ||
          get(/databases/$(database)/documents/trips/$(tripId)).data.ownerId == request.auth.uid
        );
      }
    }

    match /invites/{token} {
      allow read: if true;
      allow create: if signedIn() &&
        request.resource.data.createdBy == request.auth.uid &&
        isMember(request.resource.data.tripId);
      allow update, delete: if signedIn() && isMember(resource.data.tripId);
    }
  }
}
